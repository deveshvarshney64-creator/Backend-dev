<!DOCTYPE html>
<html>
<head>
    <title>Employee Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h2>Employee Payroll Dashboard</h2>

<a href="/employees/add">➕ Add Employee</a>

<br><br>

<table border="1" cellpadding="10">
<tr>
    <th>Name</th>
    <th>Department</th>
    <th>Salary</th>
    <th>Tax (12%)</th>
    <th>Net Salary</th>
    <th>Actions</th>
</tr>

<% if (employees && employees.length > 0) { %>

    <% employees.forEach(emp => { 
        let salary = Number(emp.salary);
        let tax = salary * 0.12;
        let net = salary - tax;
    %>

    <tr>
        <td><%= emp.name %></td>
        <td><%= emp.department %></td>
        <td><%= salary %></td>
        <td><%= tax.toFixed(2) %></td>
        <td><%= net.toFixed(2) %></td>
        <td>
            <a href="/employees/edit/<%= emp.id %>">Edit</a> |

            <!-- ⚠️ still GET (OK for mini project, but not production) -->
            <a href="/employees/delete/<%= emp.id %>">Delete</a>
        </td>
    </tr>

    <% }) %>

<% } else { %>
    <tr>
        <td colspan="6">No employees found</td>
    </tr>
<% } %>

</table>

</body>
</html>